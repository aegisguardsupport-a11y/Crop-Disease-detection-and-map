# Copy this file to .env and adjust to your environment.
# All variables use the CPL_ prefix and are loaded by cpl_crop.config.Settings.

# ----- Bundle ---------------------------------------------------------------
# Where the extracted model bundle lives. Must contain:
#   saved_model/        (TF SavedModel)
#   cpl_crop_disease_finetuned.tflite
#   cpl_id_to_label.json
#   cpl_preprocessing_config.json
CPL_BUNDLE_DIR=./exports

# ----- Logging --------------------------------------------------------------
CPL_LOG_LEVEL=INFO

# ----- API ------------------------------------------------------------------
CPL_API_HOST=127.0.0.1
CPL_API_PORT=8000
CPL_API_WORKERS=1
# JSON logs (production) vs ConsoleRenderer (dev)
CPL_API_LOG_JSON=true
# Bytes; reject uploads larger than this
CPL_API_MAX_IMAGE_BYTES=10485760
CPL_API_DEFAULT_TOPK=3
CPL_API_MAX_TOPK=10
# Reported in API responses
CPL_MODEL_VERSION=0.1.0-efficientnetb2-260
